# OpenAI API Key (used as fallback if OpenRouter fails)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Key (primary AI provider)
# Get your API key from https://openrouter.ai/keys
# OpenRouter provides access to multiple AI models (OpenAI, Anthropic, Google, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Python Chat Backend (FastAPI + LangGraph)
# The /api/chat/[sessionId]/messages route proxies to this backend. See backend/README.md.
BACKEND_URL=http://localhost:8001
# Must match BACKEND_SHARED_SECRET configured in backend/.env.
# SECURITY: the backend now FAILS CLOSED if this is empty (rejects all requests),
# because its container is publicly reachable. For LOCAL DEV without a secret,
# set BACKEND_ALLOW_INSECURE=1 in backend/.env instead — never in production.
BACKEND_SHARED_SECRET=generate_a_long_random_string

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# The browser routes its Supabase calls (auth) through our same-origin proxy
# (/api/supabase-proxy) BY DEFAULT — RU mobile carriers block *.supabase.co
# directly, so a direct call hangs on cellular. You normally do NOT need to set
# this. Override only to point at a different proxy, or set it to "direct" to
# make the browser talk to Supabase straight (previous behaviour).
# Server-side clients always reach Supabase directly and ignore this.
# NEXT_PUBLIC_SUPABASE_PROXY_URL=direct
# Optional: pin the upstream the proxy forwards to (defaults to NEXT_PUBLIC_SUPABASE_URL).
# SUPABASE_URL=https://<ref>.supabase.co

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Proxy Configuration (optional)
# Если у вас есть прокси-сервер в России, укажите его URL здесь
# Все запросы будут идти через этот прокси для улучшения доступности из России/СНГ
# NEXT_PUBLIC_PROXY_URL=https://proxy.your-domain.com

# Authentication Configuration
# Set to "true" to enable signup form, "false" to show Calendly booking (default: false)
NEXT_PUBLIC_ENABLE_SIGNUP=false

# Yandex.Metrica
# ID счётчика Яндекс.Метрики. Метрика подключается ТОЛЬКО если переменная задана.
# Задаётся как GitHub Variable в prod-окружении ("Deploy ENV"); на стейдже
# оставляем пустой, чтобы стейджинг НЕ считал метрику. Локально тоже оставьте пустым.
# NEXT_PUBLIC_YM_ID=110628199

# Yandex Object Storage (S3-compatible)
S3_BUCKET_NAME=your-bucket-name
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_REGION=ru-central1
S3_ENDPOINT=https://storage.yandexcloud.net
