# --- LLM provider (OpenRouter) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SITE_URL=https://your-domain.com
APP_TITLE=Lawyer Chat Bot

# --- Egress proxy for OpenRouter (optional) ---
# Our Yandex Cloud IP is blocked by OpenRouter's edge (HTTP 403 "Access denied
# by security policy"). Enabling this routes every OpenRouter call through a
# rotating pool of non-RU proxies. Leave PROXY_ENABLED unset for local dev /
# any egress that isn't blocked (then requests go direct — no behaviour change).
# PROXY_ENABLED=true
# Provide the pool via ONE of these (Webshare `host:port:user:pass` per line):
#   PROXY_FILE=/path/to/webshare_proxies.txt      # a mounted file (local/dev)
#   PROXY_LIST=1.2.3.4:5500:user:pass;5.6.7.8:6376:user:pass   # inline
#   PROXY_LIST_B64=<base64 of the export>          # used in the YC deploy
# Tuning (optional): PROXY_FAIL_THRESHOLD=3  PROXY_COOLDOWN_S=60  PROXY_MAX_TRIES=4

# --- SotaOCR (primary document OCR; https://sotaocr.com) ---
# Leave SOTAOCR_API_KEY unset to disable SotaOCR and fall back to OpenRouter OCR
# for every document (the previous behaviour).
# SOTAOCR_API_KEY=your_sotaocr_api_key_here
# SOTAOCR_BASE_URL=https://sotaocr.com
# SOTAOCR_MODEL_PROFILE=fast   # fast (1 scan page/page) | pro (2, higher quality)

# --- Auth between Next.js proxy and this backend ---
# Must match BACKEND_SHARED_SECRET configured in the Next.js app.
# SECURITY: if this is empty the backend FAILS CLOSED (rejects every request),
# because the container is deployed allow-unauthenticated-invoke (public). To run
# locally WITHOUT a secret, set BACKEND_ALLOW_INSECURE=1 below (dev only).
BACKEND_SHARED_SECRET=generate_a_long_random_string
# BACKEND_ALLOW_INSECURE=1   # LOCAL DEV ONLY — bypass the shared-secret check

# --- Supabase (service role; same project the Next.js app uses) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- LangSmith tracing (optional, recommended for prod diagnosis) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=lawers-chat

# --- CORS (only needed if the browser calls this backend directly) ---
# BACKEND_CORS_ORIGINS=https://your-domain.com,http://localhost:3000

# --- OpenSearch (court practice full-text search) ---
# OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_INDEX_ALIAS=court_decisions
# OPENSEARCH_TOP_K=8

# --- Logging ---
# LOGS_PATH=/var/log/app
