# --- LLM provider (OpenRouter) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SITE_URL=https://your-domain.com
APP_TITLE=Lawyer Chat Bot

# --- Auth between Next.js proxy and this backend ---
# Must match BACKEND_SHARED_SECRET configured in the Next.js app.
BACKEND_SHARED_SECRET=generate_a_long_random_string

# --- Supabase (service role; same project the Next.js app uses) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- LangSmith tracing (optional, recommended for prod diagnosis) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=lawers-chat

# --- CORS (only needed if the browser calls this backend directly) ---
# BACKEND_CORS_ORIGINS=https://your-domain.com,http://localhost:3000

# --- OpenSearch (court practice full-text search) ---
# OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_INDEX_ALIAS=court_decisions
# OPENSEARCH_TOP_K=8

# --- Logging ---
# LOGS_PATH=/var/log/app
